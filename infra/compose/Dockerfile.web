# Bun Docker build for Web service
# Based on: https://bun.com/docs/guides/ecosystem/docker

# Base stage: Set up working directory
FROM oven/bun:1 AS base
WORKDIR /usr/src/app

# Install stage: Install all dependencies (dev + prod)
FROM base AS install
RUN mkdir -p /temp/dev /temp/prod
COPY package.json bun.lock bunfig.toml /temp/dev/
COPY packages/api/package.json /temp/dev/packages/api/
COPY packages/web/package.json /temp/dev/packages/web/
COPY packages/sdk/package.json /temp/dev/packages/sdk/
COPY packages/mcp/package.json /temp/dev/packages/mcp/
RUN cd /temp/dev && bun install --frozen-lockfile

# Production dependencies only
COPY package.json bun.lock bunfig.toml /temp/prod/
COPY packages/api/package.json /temp/prod/packages/api/
COPY packages/web/package.json /temp/prod/packages/web/
COPY packages/sdk/package.json /temp/prod/packages/sdk/
COPY packages/mcp/package.json /temp/prod/packages/mcp/
RUN cd /temp/prod && bun install --frozen-lockfile --production

# Prerelease stage: Build and test
FROM base AS prerelease
COPY --from=install /temp/dev/node_modules node_modules
COPY . .
ENV NODE_ENV=production
RUN bun run typecheck
RUN bun run lint
RUN bun run format
RUN bun run check

# Release stage: Final image with prod dependencies only
FROM base AS release
COPY --from=install /temp/prod/node_modules node_modules
COPY --from=prerelease /usr/src/app/packages/web packages/web
COPY --from=prerelease /usr/src/app/package.json .
COPY --from=prerelease /usr/src/app/bun.lock .
COPY --from=prerelease /usr/src/app/bunfig.toml .

# Create non-root user for security
RUN useradd -m -u 1000 appuser && chown -R appuser:appuser /usr/src/app
USER appuser

# Health check
HEALTHCHECK --interval=30s --timeout=5s --start-period=60s --retries=3 \
  CMD bun --eval "const r = await fetch('http://localhost:7501/api/health'); console.log(r.ok ? 'ok' : 'fail')" || exit 1

EXPOSE 7501

# Run Web server (Hono + React)
ENTRYPOINT ["bun", "run", "--filter", "@allora/web", "dev"]
