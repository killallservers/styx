# Allora Development Environment Configuration
# Use this for local development with compose.dev.yml
#
# Run:
#   docker compose -f compose.dev.yml --profile gpu up -d
#
# Or without GPU (if you don't have NVIDIA):
#   docker compose -f compose.dev.yml up -d

# Application
ENVIRONMENT=dev
DOMAIN=localhost
DOCKER_REGISTRY=ghcr.io/erikwright
IMAGE_TAG=latest

# Database (using defaults is fine for local dev)
POSTGRES_PASSWORD=allora

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Optional: For local HTTPS testing (requires Caddy profile)
# CADDY_DOMAIN=localhost
# CADDY_TLS=internal  # Self-signed cert
